# Database
DATABASE_URL="postgresql://user:password@localhost:5432/buds_sessions?schema=public"

# Redis
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="your-refresh-token-secret"
JWT_REFRESH_EXPIRES_IN="7d"

# Auth0 / Clerk (external identity provider)
AUTH_PROVIDER_DOMAIN=""
AUTH_PROVIDER_CLIENT_ID=""
AUTH_PROVIDER_CLIENT_SECRET=""
AUTH_PROVIDER_AUDIENCE=""

# AWS S3 / Cloudflare R2
S3_BUCKET="buds-sessions-uploads"
S3_REGION="eu-central-1"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_ENDPOINT=""

# Email (Postmark / Mailgun)
EMAIL_PROVIDER="postmark"
EMAIL_API_KEY=""
EMAIL_FROM_ADDRESS="noreply@budssessions.com"
EMAIL_FROM_NAME="Buds Sessions"

# Firebase Cloud Messaging
FCM_PROJECT_ID=""
FCM_PRIVATE_KEY=""
FCM_CLIENT_EMAIL=""

# Stripe (Partner billing)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PUBLISHABLE_KEY=""

# Weed.de Integration
WEED_DE_API_URL=""
WEED_DE_API_KEY=""
WEED_DE_OAUTH_CLIENT_ID=""
WEED_DE_OAUTH_CLIENT_SECRET=""

# Application
PORT=3000
NODE_ENV="development"
API_PREFIX="api/v1"
CORS_ORIGINS="http://localhost:4321"

# Sentry
SENTRY_DSN=""

# Founding host cap
FOUNDING_HOST_CAP=50
