  sessionId                String?           @map("session_id")
  format                   GatheringFormat?
  city                     String?
  hostId                   String?           @map("host_id")
  startDate                DateTime?         @map("start_date") @db.Date
  endDate                  DateTime?         @map("end_date") @db.Date
  amountCents              Int               @map("amount_cents")
  hostApproved             Boolean?          @map("host_approved")
  hostApprovedAt           DateTime?         @map("host_approved_at")
  hostDeclineReason        String?           @map("host_decline_reason")
  hostCounterProposal      String?           @map("host_counter_proposal")
  editorialApproved        Boolean?          @map("editorial_approved")
  editorialApprovedAt      DateTime?         @map("editorial_approved_at")
  editorialApprovedById    String?           @map("editorial_approved_by_id")
  editorialNotes           String?           @map("editorial_notes")
  productSamplesRequired   Boolean           @default(false) @map("product_samples_required")
  productSamplesShipped    Boolean           @default(false) @map("product_samples_shipped")
  productSamplesReceived   Boolean           @default(false) @map("product_samples_received")
  leaveBehindApproved      Boolean?          @map("leave_behind_approved")
  leaveBehindDescription   String?           @map("leave_behind_description")
  brandedCardsCount        Int               @default(0) @map("branded_cards_count")
  includeProductFeedback   Boolean           @default(false) @map("include_product_feedback")
  includeLeadCapture       Boolean           @default(false) @map("include_lead_capture")
  totalImpressions         Int               @default(0) @map("total_impressions")
  totalProductRatings      Int               @default(0) @map("total_product_ratings")
  averageProductRating     Decimal?          @map("average_product_rating") @db.Decimal(3, 2)
  totalLeadsGenerated      Int               @default(0) @map("total_leads_generated")
  recapMentions            Int               @default(0) @map("recap_mentions")
  invoiceId                String?           @map("invoice_id")
  campaignId               String?           @map("campaign_id")
  notes                    String?
  createdAt                DateTime          @default(now()) @map("created_at")
  updatedAt                DateTime          @updatedAt @map("updated_at")
  deletedAt                DateTime?         @map("deleted_at")

  // Relations
  partner             PartnerOrganization        @relation(fields: [partnerId], references: [id])
  session             Session?                   @relation("sponsoredSession", fields: [sessionId], references: [id])
  host                Host?                      @relation(fields: [hostId], references: [id])
  editorialApprovedBy User?                      @relation("editorialApprover", fields: [editorialApprovedById], references: [id])
  invoice             PartnerInvoice?            @relation(fields: [invoiceId], references: [id])
  campaign            PartnerCampaign?           @relation(fields: [campaignId], references: [id])
  sessionsLinked      Session[]                  @relation("sessionSponsorship")
  welcomePackInclusions WelcomePackInclusion[]
  sponsoredCards      SponsoredConversationCard[]
  productFeedback     SponsorProductFeedback[]
  leads               PartnerLead[]

  @@index([partnerId])
  @@index([type])
  @@index([status])
  @@index([sessionId])
  @@index([format])
  @@index([city])
  @@index([hostId])
  @@index([startDate])
  @@index([endDate])
  @@index([campaignId])
  @@map("sponsorships")
}

