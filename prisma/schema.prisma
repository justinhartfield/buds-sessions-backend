// ──────────────────────────────────────────────
// TABLES — Core Platform (BACKEND_PLAN.md)
// ──────────────────────────────────────────────

model User {
  id               String    @id @default(uuid())
  authProviderId   String    @unique @map("auth_provider_id")
  email            String    @unique
  emailVerified    Boolean   @default(false) @map("email_verified")
  firstName        String    @map("first_name")
  lastName         String    @map("last_name")
  displayName      String?   @map("display_name")
  avatarUrl        String?   @map("avatar_url")
  phone            String?
  phoneVerified    Boolean   @default(false) @map("phone_verified")
  dateOfBirth      DateTime  @map("date_of_birth") @db.Date
  city             String
  countryCode      String    @default("DE") @map("country_code") @db.Char(2)
  latitude         Decimal?  @db.Decimal(10, 7)
  longitude        Decimal?  @db.Decimal(10, 7)
  weedDeUsername   String?   @unique @map("weed_de_username")
  weedDeUserId     String?   @unique @map("weed_de_user_id")
  role             UserRole  @default(GUEST)
  locale           String    @default("de-DE")
  timezone         String    @default("Europe/Berlin")
  isActive         Boolean   @default(true) @map("is_active")
  lastLoginAt      DateTime? @map("last_login_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  // Relations
  hostApplications       HostApplication[]       @relation("applicant")
  reviewedApplications   HostApplication[]       @relation("reviewer")
  host                   Host?                   @relation("hostUser")
  suspendedHosts         Host[]                  @relation("suspendedBy")
  sessionGuests          SessionGuest[]
  guestFeedback          GuestFeedback[]         @relation("feedbackUser")
  pointTransactions      PointTransaction[]      @relation("transactionUser")
  pointAdjustments       PointTransaction[]      @relation("adjustmentAdmin")
  referredUsers          HostReferral[]          @relation("referredUser")
  incidentsReported      SessionIncident[]       @relation("reporter")
  incidentsResolved      SessionIncident[]       @relation("resolver")
  notifications          Notification[]
  notificationPrefs      NotificationPreference[]
  consents               UserConsent[]
  connectionIntrosA      ConnectionIntro[]       @relation("userA")
  connectionIntrosB      ConnectionIntro[]       @relation("userB")
  adminAuditLogs         AdminAuditLog[]
  dataExportRequests     DataExportRequest[]
  dataDeletionRequests   DataDeletionRequest[]
  createdDecks           ConversationCardDeck[]
  createdFormatTemplates GatheringFormatTemplate[]
  sessionsFlagged        Session[]               @relation("flaggedBy")
  sessionsVerified       Session[]               @relation("verifiedBy")
  recapsReviewed         SessionRecap[]          @relation("recapReviewer")
  pointRedemptions       PointRedemption[]

  // Partner relations
  partnerTeamMemberships     PartnerTeamMember[]
  verifiedPartnerOrgs        PartnerOrganization[]      @relation("verifiedBy")
  partnerSuccessManaged      PartnerOrganization[]      @relation("partnerSuccessManager")
  editorialApprovedSponsor   Sponsorship[]              @relation("editorialApprover")
  reviewedInclusions         WelcomePackInclusion[]     @relation("inclusionReviewer")
  reviewedSponsoredCards     SponsoredConversationCard[] @relation("cardReviewer")
  reviewedHostKitAddOns      HostKitAddOn[]             @relation("kitReviewer")
  partnerAuditLogs           PartnerAuditLog[]
  sponsorProductFeedback     SponsorProductFeedback[]
  partnerLeads               PartnerLead[]

  @@index([email])
  @@index([city])
  @@index([countryCode])
  @@index([role])
  @@map("users")
}

model HostApplication {
  id                    String            @id @default(uuid())
  userId                String            @map("user_id")
  status                ApplicationStatus @default(PENDING)
  motivation            String
  gatheringVision       String            @map("gathering_vision")
  city                  String
  weedDeUsername        String?           @map("weed_de_username")
  preferredFormats      GatheringFormat[] @map("preferred_formats")
  hostingExperience     String?           @map("hosting_experience")
  referralCode          String?           @map("referral_code")
  referredByHostId      String?           @map("referred_by_host_id")
  reviewerId            String?           @map("reviewer_id")
  reviewedAt            DateTime?         @map("reviewed_at")
  reviewNotes           String?           @map("review_notes")
  rejectionReason       String?           @map("rejection_reason")
  foundingHostEligible  Boolean           @default(false) @map("founding_host_eligible")
  applicationScore      Decimal?          @map("application_score") @db.Decimal(5, 2)
  ipAddress             String?           @map("ip_address")
  userAgent             String?           @map("user_agent")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")

  // Relations
  user           User          @relation("applicant", fields: [userId], references: [id])
  referredByHost Host?         @relation("referredApplications", fields: [referredByHostId], references: [id])
  reviewer       User?         @relation("reviewer", fields: [reviewerId], references: [id])
  host           Host?
  referrals      HostReferral[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([referredByHostId])
  @@map("host_applications")
}

model Host {
  id                      String       @id @default(uuid())
  userId                  String       @unique @map("user_id")
  applicationId           String       @unique @map("application_id")
  tier                    HostTier     @default(BUDS_HOST)
  status                  HostStatus   @default(ACTIVE)
  hostNumber              Int          @unique @default(autoincrement()) @map("host_number")
  referralCode            String       @unique @map("referral_code")
  bio                     String?
  specialties             GatheringFormat[]
  totalSessionsHosted     Int          @default(0) @map("total_sessions_hosted")
  totalSessionsAttended   Int          @default(0) @map("total_sessions_attended")
  totalGuestsHosted       Int          @default(0) @map("total_guests_hosted")
  averageRating           Decimal?     @map("average_rating") @db.Decimal(3, 2)
  totalRatingsCount       Int          @default(0) @map("total_ratings_count")
  pointsBalance           Int          @default(0) @map("points_balance")
  pointsLifetimeEarned    Int          @default(0) @map("points_lifetime_earned")
  pointsLifetimeSpent     Int          @default(0) @map("points_lifetime_spent")
  tierPromotedAt          DateTime?    @map("tier_promoted_at")
  firstSessionAt          DateTime?    @map("first_session_at")
  lastSessionAt           DateTime?    @map("last_session_at")
  weedDeBadgeSynced       Boolean      @default(false) @map("weed_de_badge_synced")
  weedDeBadgeSyncedAt     DateTime?    @map("weed_de_badge_synced_at")
  suspensionReason        String?      @map("suspension_reason")
  suspendedAt             DateTime?    @map("suspended_at")
  suspendedById           String?      @map("suspended_by_id")
  onboardingCompletedAt   DateTime?    @map("onboarding_completed_at")
  createdAt               DateTime     @default(now()) @map("created_at")
  updatedAt               DateTime     @updatedAt @map("updated_at")
  deletedAt               DateTime?    @map("deleted_at")

  // Relations
  user                  User              @relation("hostUser", fields: [userId], references: [id])
  application           HostApplication   @relation(fields: [applicationId], references: [id])
  suspendedBy           User?             @relation("suspendedBy", fields: [suspendedById], references: [id])
  welcomePack           WelcomePack?
  sessions              Session[]
  sessionRecaps         SessionRecap[]
  guestFeedback         GuestFeedback[]
  pointTransactions     PointTransaction[]
  pointRedemptions      PointRedemption[]
  referralsGiven        HostReferral[]     @relation("referrer")
  referredApplications  HostApplication[]  @relation("referredApplications")
  connectionIntros      ConnectionIntro[]
  milestones            HostMilestone[]
  sponsorships          Sponsorship[]
  hostKitRequests       HostKitRequest[]

  @@index([tier])
  @@index([status])
  @@index([referralCode])
  @@index([averageRating])
  @@index([totalSessionsHosted])
  @@map("hosts")
}

model WelcomePack {
  id                    String             @id @default(uuid())
  hostId                String             @unique @map("host_id")
  variant               WelcomePackVariant
  status                WelcomePackStatus  @default(PENDING_APPROVAL)
  shippingName          String             @map("shipping_name")
  shippingAddressLine1  String             @map("shipping_address_line1")
  shippingAddressLine2  String?            @map("shipping_address_line2")
  shippingCity          String             @map("shipping_city")
  shippingPostalCode    String             @map("shipping_postal_code")
  shippingCountryCode   String             @map("shipping_country_code") @db.Char(2)
  shippingPhone         String?            @map("shipping_phone")
  fulfillmentProvider   String?            @map("fulfillment_provider")
  fulfillmentOrderId    String?            @map("fulfillment_order_id")
  trackingNumber        String?            @map("tracking_number")
  trackingUrl           String?            @map("tracking_url")
  carrier               String?
  estimatedDeliveryDate DateTime?          @map("estimated_delivery_date") @db.Date
  shippedAt             DateTime?          @map("shipped_at")
  deliveredAt           DateTime?          @map("delivered_at")
  deliveryConfirmedBy   String?            @map("delivery_confirmed_by")
  deliveryPhotoUrl      String?            @map("delivery_photo_url")
  returnReason          String?            @map("return_reason")
  returnedAt            DateTime?          @map("returned_at")
  replacementPackId     String?            @unique @map("replacement_pack_id")
  notes                 String?
  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt             DateTime           @updatedAt @map("updated_at")

  // Relations
  host            Host              @relation(fields: [hostId], references: [id])
  replacementPack WelcomePack?      @relation("replacementChain", fields: [replacementPackId], references: [id])
  replacedBy      WelcomePack?      @relation("replacementChain")
  items           WelcomePackItem[]

  @@index([status])
  @@index([trackingNumber])
  @@index([fulfillmentOrderId])
  @@map("welcome_packs")
}

model WelcomePackItem {
  id                String    @id @default(uuid())
  welcomePackId     String    @map("welcome_pack_id")
  itemName          String    @map("item_name")
  itemSku           String?   @map("item_sku")
  quantity          Int       @default(1)
  isIncluded        Boolean   @default(true) @map("is_included")
  substitutionNote  String?   @map("substitution_note")
  createdAt         DateTime  @default(now()) @map("created_at")

  // Monetization additions
  isPartnerProduct  Boolean   @default(false) @map("is_partner_product")
  partnerId         String?   @map("partner_id")
  inclusionId       String?   @map("inclusion_id")

  // Relations
  welcomePack       WelcomePack           @relation(fields: [welcomePackId], references: [id])
  partner           PartnerOrganization?  @relation(fields: [partnerId], references: [id])
  inclusion         WelcomePackInclusion? @relation(fields: [inclusionId], references: [id])

  @@map("welcome_pack_items")
}

model Session {
  id                          String          @id @default(uuid())
  hostId                      String          @map("host_id")
  title                       String
  description                 String?
  format                      GatheringFormat
  customFormatName            String?         @map("custom_format_name")
  status                      SessionStatus   @default(DRAFT)
  currentPhase                SessionPhase    @default(NOT_STARTED) @map("current_phase")
  scheduledDate               DateTime        @map("scheduled_date") @db.Date
  scheduledStartTime          DateTime        @map("scheduled_start_time") @db.Time()
  scheduledEndTime            DateTime        @map("scheduled_end_time") @db.Time()
  timezone                    String
  actualStartTime             DateTime?       @map("actual_start_time")
  actualEndTime               DateTime?       @map("actual_end_time")
  warmUpStartedAt             DateTime?       @map("warm_up_started_at")
  warmUpEndedAt               DateTime?       @map("warm_up_ended_at")
  mainEventStartedAt          DateTime?       @map("main_event_started_at")
  mainEventEndedAt            DateTime?       @map("main_event_ended_at")
  windDownStartedAt           DateTime?       @map("wind_down_started_at")
  windDownEndedAt             DateTime?       @map("wind_down_ended_at")
  venueType                   String          @map("venue_type")
  venueName                   String?         @map("venue_name")
  venueAddress                String?         @map("venue_address")
  venueCity                   String          @map("venue_city")
  venueCountryCode            String          @map("venue_country_code") @db.Char(2)
  venueLatitude               Decimal?        @map("venue_latitude") @db.Decimal(10, 7)
  venueLongitude              Decimal?        @map("venue_longitude") @db.Decimal(10, 7)
  minGuests                   Int             @default(4) @map("min_guests")
  maxGuests                   Int             @default(12) @map("max_guests")
  idealGuests                 Int?            @map("ideal_guests")
  checkInCode                 String?         @unique @map("check_in_code")
  checkInQrUrl                String?         @map("check_in_qr_url")
  isPrivate                   Boolean         @default(true) @map("is_private")
  atmosphereChecklist         Json?           @map("atmosphere_checklist")
  supplyChecklist             Json?           @map("supply_checklist")
  conversationCardDeckId      String?         @map("conversation_card_deck_id")
  playlistUrl                 String?         @map("playlist_url")
  signatureElement            String?         @map("signature_element")
  hostPrivateNotes            String?         @map("host_private_notes")
  cancellationReason          String?         @map("cancellation_reason")
  cancelledAt                 DateTime?       @map("cancelled_at")
  flagReason                  String?         @map("flag_reason")
  flaggedAt                   DateTime?       @map("flagged_at")
  flaggedById                 String?         @map("flagged_by_id")
  verifiedAt                  DateTime?       @map("verified_at")
  verifiedById                String?         @map("verified_by_id")
  pointsDistributed           Boolean         @default(false) @map("points_distributed")
  pointsDistributedAt         DateTime?       @map("points_distributed_at")
  sessionScore                Decimal?        @map("session_score") @db.Decimal(5, 2)
  totalFeedbackCount          Int             @default(0) @map("total_feedback_count")
  averageFeedbackRating       Decimal?        @map("average_feedback_rating") @db.Decimal(3, 2)
  createdAt                   DateTime        @default(now()) @map("created_at")
  updatedAt                   DateTime        @updatedAt @map("updated_at")
  deletedAt                   DateTime?       @map("deleted_at")

  // Monetization additions
  isSponsored                    Boolean  @default(false) @map("is_sponsored")
  primarySponsorId               String?  @map("primary_sponsor_id")
  sponsorshipId                  String?  @map("sponsorship_id")
  sponsorProductFeedbackEnabled  Boolean  @default(false) @map("sponsor_product_feedback_enabled")
  sponsorLeadCaptureEnabled      Boolean  @default(false) @map("sponsor_lead_capture_enabled")

  // Relations
  host                  Host                          @relation(fields: [hostId], references: [id])
  conversationCardDeck  ConversationCardDeck?         @relation(fields: [conversationCardDeckId], references: [id])
  flaggedBy             User?                         @relation("flaggedBy", fields: [flaggedById], references: [id])
  verifiedBy            User?                         @relation("verifiedBy", fields: [verifiedById], references: [id])
  primarySponsor        PartnerOrganization?          @relation(fields: [primarySponsorId], references: [id])
  sponsorship           Sponsorship?                  @relation("sessionSponsorship", fields: [sponsorshipId], references: [id])
  guests                SessionGuest[]
  recap                 SessionRecap?
  recapPhotos           SessionRecapPhoto[]
  feedback              GuestFeedback[]
  pointTransactions     PointTransaction[]
  cardUsage             SessionConversationCardUsage[]
  incidents             SessionIncident[]
  connectionIntros      ConnectionIntro[]
  sponsorships          Sponsorship[]                 @relation("sponsoredSession")
  sponsorProductFeedback SponsorProductFeedback[]
  partnerLeads          PartnerLead[]
  hostKitRequests       HostKitRequest[]

  @@index([hostId])
  @@index([status])
  @@index([scheduledDate])
  @@index([format])
  @@index([venueCity])
  @@index([currentPhase])
  @@index([checkInCode])
  @@map("sessions")
}

model SessionGuest {
  id                  String     @id @default(uuid())
  sessionId           String     @map("session_id")
  userId              String     @map("user_id")
  rsvpStatus          RSVPStatus @default(INVITED) @map("rsvp_status")
  invitedAt           DateTime   @map("invited_at")
  invitedBy           String     @map("invited_by")
  inviteMessage       String?    @map("invite_message")
  respondedAt         DateTime?  @map("responded_at")
  declineReason       String?    @map("decline_reason")
  checkedInAt         DateTime?  @map("checked_in_at")
  checkedInMethod     String?    @map("checked_in_method")
  checkedOutAt        DateTime?  @map("checked_out_at")
  isPlusOne           Boolean    @default(false) @map("is_plus_one")
  plusOneName          String?    @map("plus_one_name")
  dietaryNotes        String?    @map("dietary_notes")
  isFirstTimeGuest    Boolean    @default(false) @map("is_first_time_guest")
  isFirstTimeWithHost Boolean    @default(false) @map("is_first_time_with_host")
  pointsAwarded       Int?       @map("points_awarded")
  pointsAwardedAt     DateTime?  @map("points_awarded_at")
  feedbackSubmitted   Boolean    @default(false) @map("feedback_submitted")
  noShowReason        String?    @map("no_show_reason")
  waitlistPosition    Int?       @map("waitlist_position")
  createdAt           DateTime   @default(now()) @map("created_at")
  updatedAt           DateTime   @updatedAt @map("updated_at")

  // Relations
  session  Session         @relation(fields: [sessionId], references: [id])
  user     User            @relation(fields: [userId], references: [id])
  feedback GuestFeedback[]

  @@unique([sessionId, userId])
  @@index([sessionId])
  @@index([userId])
  @@index([rsvpStatus])
  @@index([sessionId, rsvpStatus])
  @@map("session_guests")
}

model SessionRecap {
  id                    String    @id @default(uuid())
  sessionId             String    @unique @map("session_id")
  hostId                String    @map("host_id")
  summary               String
  highlights            String[]
  whatWorked             String?   @map("what_worked")
  whatToImprove          String?   @map("what_to_improve")
  guestCountActual      Int       @map("guest_count_actual")
  energyLevel           Int?      @map("energy_level")
  conversationDepth     Int?      @map("conversation_depth")
  overallSatisfaction   Int?      @map("overall_satisfaction")
  bestConversationTopic String?   @map("best_conversation_topic")
  signatureMoment       String?   @map("signature_moment")
  wouldRepeatFormat     Boolean?  @map("would_repeat_format")
  strainsFeatured       String[]  @map("strains_featured")
  foodServed            String?   @map("food_served")
  musicPlaylistUrl      String?   @map("music_playlist_url")
  postcardFilled        Boolean   @default(false) @map("postcard_filled")
  isPublished           Boolean   @default(false) @map("is_published")
